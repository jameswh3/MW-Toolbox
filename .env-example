#Multiple Scripts
TENANT_ID="your-tenant-id-guid"

# Compliance scripts
UPN="admin@yourtenant.onmicrosoft.com"

# Blob storage scripts
STORAGE_ACCOUNT_NAME="yourstorageaccount"
RESOURCE_GROUP_NAME="your-resource-group"
CONTAINER_NAME="yourcontainer"

# Database Scripts
SQL_SERVER_NAME="yoursqlserver"
SQL_RESOURCE_GROUP_NAME="your-sql-resource-group"

# Fabric Scripts
FABRIC_RESOURCE_GROUP_NAME="your-fabric-resource-group"
FABRIC_NAME="yourfabricname"

# Power Platform Scripts (App Registration needs to be added as S2S User w/ sys admin for each environment in PPAC)
POWER_PLAT_CLIENT_ID="your-power-platform-client-id"
POWER_PLAT_CLIENT_SECRET="your-power-platform-client-secret"
POWER_PLAT_TENANT_DOMAIN="yourtenant.onmicrosoft.com"

# Power Platform Transcript Script
POWER_PLAT_ORG_URL="yourorg.crm.dynamics.com"

# Azure VM Scripts
AZURE_SUBSCRIPTION_ID="your-azure-subscription-id"
AZURE_VM_RESOURCE_GROUP_NAME="your-vm-resource-group"

#SharePoint Online Scripts
SHAREPOINT_ONLINE_CLIENT_ID="your-sharepoint-client-id"
SHAREPOINT_ONLINE_CERTIFICATE_PATH="c:\path\to\your\certificate.pfx"
SHAREPOINT_ONLINE_CERTIFICATE_PASSWORD="your-certificate-password"
SHAREPOINT_ONLINE_SITE_ID="your-sharepoint-site-id-guid"
SHAREPOINT_ONLINE_DRIVE_ID="your-sharepoint-drive-id"
SHAREPOINT_ONLINE_FOLDER_PATH="https://yourtenant.sharepoint.com/sites/yoursite/yourfolder"
SHAREPOINT_ONLINE_ADMIN_URL="https://yourtenant-admin.sharepoint.com"
SHAREPOINT_ONLINE_SITE="https://yourtenant.sharepoint.com/sites/yoursite"
SHAREPOINT_ONLINE_TENANT_DOMAIN="yourtenant.onmicrosoft.com"
SHAREPOINT_ONLINE_LIBRARY="your-library-name"

# Copilot API Python Notebook
CopilotAPIPythonClient_Id="YOUR_CLIENT_ID"
CopilotAPIPythonClient_Tenant="YOUR_TENANT_ID"

# Copilot Report API Python Notebook
CopilotReportAPIPythonClient_Id="YOUR_REPORT_CLIENT_ID"
CopilotReportAPIPythonClient_Secret="YOUR_REPORT_CLIENT_SECRET"

# Azure Maps API
AZURE_MAPS_CLIENT_ID="your-azure-maps-client-id"
AZURE_MAPS_SUBSCRIPTION_KEY="your-azure-maps-subscription-key"

# Azure Key Vault Scripts
KEY_VAULT_NAME="yourkeyvaultname"
KEY_VAULT_RESOURCE_GROUP_NAME="your-keyvault-resource-group"

# RDCMan Script (Misc/Update-RDCManFile.ps1)
RDCMAN_SOURCE_PATH=""
RDCMAN_DESTINATION_PATH=""
RDCMAN_RDG_FILENAME="j3msftlab.rdg"
RDCMAN_GROUP_NAME="Imported RDPs (Downloads)"

# ── Salesforce Synthetic Data Generator (Salesforce/salesforce_synthetic_data_generator.ipynb) ──
# Auth method: "password" (Option A) or "client_credentials" (Option B)
SF_AUTH_METHOD="client_credentials"
# My Domain hostname (used as the OAuth token endpoint for client_credentials flow)
# Find it at: Setup → My Domain
SF_MY_DOMAIN="yourorg.develop.my.salesforce.com"
# Max records per REST API request (200 is the Salesforce limit)
SF_API_BATCH_SIZE=200
# Local output directory for CSV / JSON / Excel exports
SF_OUTPUT_DIR="c:/temp"

# Option A — Username / Password / Security Token
# Obtain your security token: Salesforce → Settings → My Personal Information → Reset My Security Token
SF_USERNAME=
SF_PASSWORD=
SF_SECURITY_TOKEN=

# Option B — Connected App Client Credentials (recommended)
# Obtain from: Setup → App Manager → your Connected App → Consumer Key / Consumer Secret
SF_CLIENT_ID="your-connected-app-consumer-key"
SF_CLIENT_SECRET="your-connected-app-consumer-secret"

# ── Snowflake MCP Server Setup (Snowflake/snowflake_mcp_server_setup.ipynb) ──────────────────────

# --- Required: Admin connection (used by the notebook to provision objects) ---
# Account identifier: use org-account format with HYPHENS, not underscores.
# Example: myorg-myaccount  (NOT myorg_myaccount -- underscores break MCP connections)
# Find it in Snowsight: Admin -> Accounts, or from your account URL before .snowflakecomputing.com
SNOWFLAKE_ACCOUNT="myorg-myaccount"
SNOWFLAKE_ADMIN_USER="your-admin-username"
SNOWFLAKE_ADMIN_PASSWORD="your-admin-password"
SNOWFLAKE_ADMIN_ROLE="ACCOUNTADMIN"
SNOWFLAKE_WAREHOUSE="your-warehouse"

# --- Required: Target database/schema where the MCP server object will be created ---
SNOWFLAKE_DATABASE="your-database"
SNOWFLAKE_SCHEMA="your-schema"

# --- Optional: Override DB/schema for the MCP server object (defaults to SNOWFLAKE_DATABASE/SCHEMA) ---
# SNOWFLAKE_MCP_DATABASE="your-mcp-database"
# SNOWFLAKE_MCP_SCHEMA="your-mcp-schema"

# --- Optional: MCP server object name (default: TRIAL_MCP_SERVER) ---
# SNOWFLAKE_MCP_SERVER_NAME="TRIAL_MCP_SERVER"

# --- Optional: SQL execution tool (enabled by default) ---
# SNOWFLAKE_MCP_ENABLE_SQL_EXEC_TOOL="true"
# SNOWFLAKE_MCP_TOOL_NAME="sql_exec_tool"
# SNOWFLAKE_MCP_TOOL_TITLE="SQL Execution Tool"
# SNOWFLAKE_MCP_TOOL_DESCRIPTION="A tool to execute SQL queries against the connected Snowflake database."

# --- Optional: Cortex Analyst (NL2SQL) tool ---
# Set to true to include a CORTEX_ANALYST_MESSAGE tool in the MCP server.
# SNOWFLAKE_MCP_ENABLE_CORTEX_ANALYST="false"
# SNOWFLAKE_MCP_ANALYST_IDENTIFIER="database.schema.semantic_view_name"
# SNOWFLAKE_MCP_ANALYST_TOOL_NAME="cortex_analyst"
# SNOWFLAKE_MCP_ANALYST_TOOL_TITLE="Cortex Analyst"
# SNOWFLAKE_MCP_ANALYST_TOOL_DESCRIPTION="Natural language to SQL via Cortex Analyst semantic view."

# --- Optional: Provision a new semantic view (for Cortex Analyst) ---
# SNOWFLAKE_MCP_PROVISION_SEMANTIC_VIEW="false"
# SNOWFLAKE_MCP_SEMANTIC_VIEW_TEMPLATE="tpch"
# SNOWFLAKE_MCP_SEMANTIC_VIEW_DATABASE="your-database"
# SNOWFLAKE_MCP_SEMANTIC_VIEW_SCHEMA="your-schema"
# SNOWFLAKE_MCP_SEMANTIC_VIEW_NAME="TPCH_NL2SQL"
# SNOWFLAKE_MCP_SV_SOURCE_DATABASE="SNOWFLAKE_SAMPLE_DATA"
# SNOWFLAKE_MCP_SV_SOURCE_SCHEMA="TPCH_SF1"

# --- Optional: Cortex Search (RAG retrieval) tool ---
# Set to true to include a CORTEX_SEARCH_SERVICE_QUERY tool in the MCP server.
# SNOWFLAKE_MCP_ENABLE_CORTEX_SEARCH="false"
# SNOWFLAKE_MCP_SEARCH_IDENTIFIER="database.schema.cortex_search_service_name"
# SNOWFLAKE_MCP_SEARCH_TOOL_NAME="cortex_search"
# SNOWFLAKE_MCP_SEARCH_TOOL_TITLE="Cortex Search"
# SNOWFLAKE_MCP_SEARCH_TOOL_DESCRIPTION="Retrieval over a Cortex Search Service for grounded responses."

# --- Optional: Provision a new Cortex Search Service ---
# SNOWFLAKE_MCP_PROVISION_CORTEX_SEARCH="false"
# SNOWFLAKE_MCP_SEARCH_DATABASE="your-database"
# SNOWFLAKE_MCP_SEARCH_SCHEMA="your-schema"
# SNOWFLAKE_MCP_SEARCH_SERVICE_NAME="mcp_search_service"
# SNOWFLAKE_MCP_SEARCH_ON_COLUMN="your_text_column"
# SNOWFLAKE_MCP_SEARCH_SOURCE_SQL="SELECT your_text_column FROM your_table"
# SNOWFLAKE_MCP_SEARCH_WAREHOUSE="your-warehouse"
# SNOWFLAKE_MCP_SEARCH_ATTRIBUTES="col1,col2"
# SNOWFLAKE_MCP_SEARCH_TARGET_LAG="1 hour"

# --- Optional: OAuth config for Copilot Studio / VS Code connection output ---
# AZURE_TENANT_ID="your-entra-tenant-id"
# SNOWFLAKE_APP_ID_URI="api://your-entra-app-registration-app-id-uri"

# --- Optional: OAuth user access check (Step 8) ---
# SNOWFLAKE_OAUTH_USER="SNOWSQL_OAUTH_USER"
# SNOWFLAKE_OAUTH_ROLE="ANALYST"
# SNOWFLAKE_MCP_APPLY_OAUTH_GRANTS="false"